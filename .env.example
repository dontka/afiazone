# Application
APP_NAME=AfiaZone
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:GENERATED_KEY_HERE
APP_URL=http://afiazone.test
APP_TIMEZONE=Africa/Lubumbashi

# Database (Laragon Defaults)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=afiazone
DB_USER=root
DB_PASSWORD=

# Cache (File-based)
CACHE_DRIVER=file
CACHE_HOST=127.0.0.1
CACHE_PORT=null

# Queue (File-based)
QUEUE_DRIVER=file
QUEUE_HOST=127.0.0.1
QUEUE_PORT=null

# Session (File-based)
SESSION_DRIVER=file
SESSION_HOST=127.0.0.1
SESSION_PORT=null

# Mail — Mailpit (Laragon local SMTP catcher, web UI: http://localhost:8025)
MAIL_DRIVER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@afiazone.test
MAIL_FROM_NAME=AfiaZone

# File Storage (Local filesystem)
FILESYSTEM_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Mobile Money Integration (Examples)
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
MTN_MOMO_API_KEY=
MTN_MOMO_API_SECRET=
WAVE_API_KEY=
WAVE_API_SECRET=

# PSP (Payment Service Provider) - Card Payments
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
MONETICO_MERCHANT_ID=
MONETICO_SECRET_KEY=

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Monitoring & Error Tracking
SENTRY_DSN=

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=google

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Security
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
CSRF_ENABLED=true
HTTPS_REDIRECT=false

# Feature Flags
FEATURE_WALLET_ENABLED=true
FEATURE_PRESCRIPTIONS_ENABLED=true
FEATURE_KYC_ENABLED=true
FEATURE_DELIVERY_TRACKING=true

# Pagination
PAGINATION_PER_PAGE=20

# API Documentation
API_DOC_ENABLED=true
API_DOC_PATH=/api/docs
